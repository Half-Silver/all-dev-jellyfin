#!/bin/sh
# remove hook: runs only on `snap remove` — the ONE place the uninstall
# confirmation (deployment_stop) is sent to Control Tower. Best-effort — don't
# let a callback failure block removal.
export PATH="$SNAP/usr/sbin:$SNAP/usr/bin:$SNAP/sbin:$SNAP/bin:$PATH"

if [ -x "$SNAP/bin/ct-engine-run" ]; then
    "$SNAP/bin/ct-engine-run" hook-remove || true
fi

exit 0
