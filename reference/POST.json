{
  "snaps": [
    {
      "name": "all-dev-jellyfin",
      "refresh": true
    }
  ],
  "snap_config": [
    {
      "snap": "all-dev-jellyfin",
      "settings": {
        "ct-node-id": "<ALL_APP_NODE_ID>",
        "ct-callback-url": "<ALL_APP_CALLBACK_URL>",
        "ct-deployment-id": "<ALL_APP_DEPLOYMENT_ID>"
      }
    }
  ],
  "ignore_failures": false,
  "pre_service_actions": [],
  "post_service_actions": [
    {
      "names": [
        "all-dev-jellyfin.ct-engine",
        "all-dev-jellyfin.media-portal"
      ],
      "action": "restart"
    }
  ],
  "interface_connections": [
    {
      "plug": "all-dev-jellyfin:network",
      "slot": ":network",
      "action": "connect"
    },
    {
      "plug": "all-dev-jellyfin:network-bind",
      "slot": ":network-bind",
      "action": "connect"
    },
    {
      "plug": "all-dev-jellyfin:opengl",
      "slot": ":opengl",
      "action": "connect"
    },
    {
      "plug": "all-dev-jellyfin:removable-media",
      "slot": ":removable-media",
      "action": "connect"
    },
    {
      "plug": "all-dev-jellyfin:mount-observe",
      "slot": ":mount-observe",
      "action": "connect"
    },
    {
      "plug": "all-dev-jellyfin:firewall-control",
      "slot": ":firewall-control",
      "action": "connect"
    },
    {
      "plug": "all-dev-jellyfin:fuse-support",
      "slot": ":fuse-support",
      "action": "connect"
    }
  ]
}
